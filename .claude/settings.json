{
  "$comment": "テンプレートのデフォルト settings.json。新規プロジェクト派生後、必要に応じて WebFetch ドメイン等を追加すること。",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}
