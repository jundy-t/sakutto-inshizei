# ConoHa WING FTPS デプロイ設定
#
# 使い方:
#   1. このファイルを .env にコピー: cp .env.example .env
#   2. 実際の値に書き換える（特に FTP_REMOTE_DIR をこのツール用に変更）
#   3. .env は .gitignore で除外されるので Git に上がらない
#
# ConoHa WING のFTPアカウントは haraochi.jp 配下で1つ作成すれば全サブドメインに到達可能。
# 詳細な作成手順は README.md「デプロイ設定」を参照。

# FTPS接続情報（全ツール共通。haraochi.jp で1つ作ったFTPアカウントを使い回す）
FTP_HOST=www106.conoha.ne.jp
FTP_PORT=21
FTP_USER=deploy@haraochi.jp
FTP_PASSWORD=your-strong-password-here

# このツール固有のリモートディレクトリ
# 構造: /home/<契約番号>/public_html/<サブドメイン>/
# 例: /home/c7983099/public_html/keihi-hantei.haraochi.jp/
FTP_REMOTE_DIR=/home/c7983099/public_html/sakutto-inshizei.haraochi.jp/
